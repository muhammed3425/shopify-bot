# SHOPIFY API
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_PASSWORD=your_password_here
SHOPIFY_STORE_URL=your-store.myshopify.com

# GOOGLE TRENDS API
GOOGLE_TRENDS_API_KEY=your_api_key_here

# AMAZON API (RapidAPI)
AMAZON_API_KEY=your_api_key_here
AMAZON_API_HOST=amazon-api.rapidapi.com

# ALIEXPRESS API
ALIEXPRESS_API_KEY=your_api_key_here

# PROXY (Opsiyonel - Free)
USE_PROXY=false
PROXY_LIST=proxy1.com:8080,proxy2.com:8080

# RENDER
PORT=10000
